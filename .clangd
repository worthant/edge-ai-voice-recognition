CompileFlags:
  CompilationDatabase: .pio/build/esp32-s3-devkitc-1
  Add:
    - "-DUSE_CUSTOM_KWS=1"
    - "-I/home/boris/.platformio/packages/framework-espidf/components/esp_driver_i2s/include"
    - "-I/home/boris/.platformio/packages/framework-espidf/components/esp_timer/include"
    - "-I/home/boris/.platformio/packages/framework-espidf/components/esp_driver_spi/include"
  Remove:
    - "-mlongcalls"
    - "-fstrict-volatile-bitfields"
    - "-fno-shrink-wrap"
    - "-fno-tree-switch-conversion"
    - "-fno-jump-tables"
    - "-mdisable-hardware-atomics"
Diagnostics:
  Suppress:
    - unused-includes
    - pp_file_not_found
